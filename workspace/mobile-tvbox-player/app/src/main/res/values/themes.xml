<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 基础主题 -->
    <style name="Theme.MobileTVBox" parent="Theme.Material3.DayNight.DarkActionBar">
        <!-- 主色调 -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        
        <!-- 次要颜色 -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_dark</item>
        <item name="colorOnSecondary">@color/black</item>
        
        <!-- 背景和表面 -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        
        <!-- 错误颜色 -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/white</item>
        
        <!-- 状态栏颜色 -->
        <item name="android:statusBarColor">@color/primary_dark</item>
        
        <!-- 导航栏颜色 -->
        <item name="android:navigationBarColor">@color/primary_dark</item>
    </style>
    
    <!-- 播放器主题（全屏） -->
    <style name="Theme.MobileTVBox.Player" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowKeepScreenOn">true</item>
        <item name="android:screenOrientation">landscape</item>
    </style>
    
    <!-- 按钮样式 -->
    <style name="AppButton" parent="Widget.Material3.Button">
        <item name="cornerRadius">8dp</item>
        <item name="android:textAllCaps">false</item>
    </style>
    
    <!-- 主要按钮 -->
    <style name="AppButton.Primary">
        <item name="backgroundTint">@color/primary</item>
    </style>
    
    <!-- 卡片样式 -->
    <style name="AppCard" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">4dp</item>
    </style>
    
    <!-- 文本样式 -->
    <style name="AppText.Title">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>
    
    <style name="AppText.Body">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
    </style>
    
    <!-- 加载对话框样式 -->
    <style name="LoadingDialog" parent="Theme.Material3.Light.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
    </style>
</resources>
